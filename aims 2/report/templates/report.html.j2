<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AIMS — Implicit Motivation Report — {{ profile.name }}</title>
<link rel="stylesheet" href="/static/aims.css">
</head>
<body>

{% macro pbar(name, r, enabled, todo=False) %}
  <div class="motive-row">
    <div class="head">
      <span class="name">{{ name }}{% if todo %} <span class="todo">[to be done]</span>{% endif %}</span>
      {% if enabled and r and r.percentile is not none %}
        <span class="pct">{{ r.percentile }}<span class="bandname">{{ r.band }}</span></span>
      {% else %}<span class="pct muted" style="font-size:11px;">—</span>{% endif %}
    </div>
    <div class="pscale {% if not enabled %}pscale-disabled{% endif %}">
      <div class="pscale-track"><span class="b b1"></span><span class="b b2"></span><span class="b b3"></span><span class="b b4"></span><span class="b b5"></span></div>
      {% if enabled and r and r.percentile is not none %}
        <span class="pscale-marker" style="left:{{ r.percentile }}%;"></span>
      {% endif %}
    </div>
  </div>
{% endmacro %}

{% macro meter(evidence) %}
  <span class="meter {{ evidence|evi }}"><i></i><i></i><i></i><i></i></span><span class="evi {{ evidence|evi }}">{{ evidence }}</span>
{% endmacro %}

<div class="toolbar">
  <a class="alt" href="javascript:window.print()">Print</a>
  <a href="{{ '/report/%s.pdf'|format(profile.subject_id) }}">Download PDF</a>
</div>

{% for pg in pages %}
{% set pn = loop.index %}
{# ============================================================ TITLE #}
{% if pg.type == 'title' %}
<section class="page title-page">
  {% if is_sample %}<div class="sample-wm">SAMPLE</div>{% endif %}
  <div class="title-main">
    <div class="brandline">AI-Powered Implicit Motive System</div>
    <h1>Implicit <b>Motivation</b> Report</h1>
    <div class="subject">{{ profile.name }}
      {% if subject_role %}<span class="role">{{ subject_role }}</span>{% endif %}
    </div>
    <div class="title-meta">
      <div class="row">
        <div class="label">On behalf of:</div>
        <div class="logo-box">{{ client or 'Client logo' }}</div>
      </div>
      <div class="row">
        <div class="label">Person:</div>
        <div class="title-date">{{ profile.name }}</div>
      </div>
      <div class="title-date">{{ date }}</div>
    </div>
  </div>
  <div class="title-rail">
    <div class="wm">AIMS</div>
    <div class="wm-words"><div>AI-Powered</div><div>Implicit</div><div>Motive</div><div>System</div></div>
  </div>
</section>

{# ============================================================ CONFIDENTIAL + TOC #}
{% elif pg.type == 'confidential' %}
<section class="page">
  <div class="page__body">
    <p class="section-label azure">Confidential</p>
    <p class="confidential"><b>Confidential:</b> This document has been prepared for the exclusive
      use of the client named. Because it contains confidential information, its use should be
      controlled and limited to the executives concerned. This information is given in good faith
      and is believed to be correct but may require verification. For more on approach and
      assessment methodology, see the appendix.</p>
    <div class="toc">
      <h2>Table of Contents</h2>
      <ol>
        <li><span class="t">Implicit Motivation Executive Summary</span><span class="pg">3</span></li>
        {% set ns = namespace(p=4) %}
        {% for m in motives %}
          {% set r = profile.motives.get(m.key) %}
          <li><span class="t">{{ m.display_name }} Motive in Detail{% if not (r and r.enabled) %} <span class="todo">[to be done]</span>{% endif %}</span><span class="pg">{% if r and r.enabled %}{{ ns.p }}{% else %}—{% endif %}</span></li>
          {% if r and r.enabled %}
            <li class="sub"><span class="t">Overall</span><span class="pg">{{ ns.p }}</span></li>
            <li class="sub"><span class="t">Expressions</span><span class="pg">{{ ns.p + 1 }}</span></li>
            {% set ns.p = ns.p + 2 %}
          {% endif %}
        {% endfor %}
        <li><span class="t">Appendix (Definitions &amp; Methodology)</span><span class="pg">{{ ns.p }}</span></li>
      </ol>
    </div>
  </div>
  <footer class="page__footer"><span>{{ date }}</span><span>{{ copyright }}</span><span>{{ pn }}</span></footer>
</section>

{# ============================================================ EXECUTIVE SUMMARY #}
{% elif pg.type == 'exec' %}
<section class="page">
  <header class="page__header"><span class="mark">AIMS Motivation Report</span><span class="who">{{ profile.name }}</span><span class="spacer"></span><span class="tag">Implicit Motivation</span></header>
  {% if is_sample %}<span class="sample-chip">SAMPLE</span>{% endif %}
  <div class="page__body">
    <h1 class="page-title">Implicit Motivation Executive Summary <span class="sub">(Percentiles)</span></h1>
    <div class="split">
      <div class="col-wide">
        {% for m in motives %}
          {% set r = profile.motives.get(m.key) %}
          {{ pbar(m.display_name, r, r and r.enabled, todo=not (r and r.enabled)) }}
        {% endfor %}
        <div class="pscale-legend"><span>Sig. low</span><span>Low</span><span>Average</span><span>High</span><span>Sig. high</span></div>
        {% if sample_relative %}<p class="note">Percentiles are sample-relative (positioned within the current reference cohort), not yet externally normed.</p>{% endif %}
      </div>
      <div class="col-narrow">
        <div class="summary-box">
          <div class="ttl">S U M M A R Y</div>
          <p style="margin:0;">Implicit motivation is the set of deep, nonconscious emotional
          drives that energize people over time. They do not indicate what people <i>can</i> do,
          but what people are <i>motivated</i> to do — measured through a projective test of
          spontaneous expression and AI-based motivational scoring.</p>
        </div>
      </div>
    </div>
    <div class="block" style="margin-top:14px;">
      <p class="section-label">Key Findings</p>
      {% for m in motives %}
        {% set r = profile.motives.get(m.key) %}
        {% if r and r.enabled %}
          {% set nar = N[m.key] %}
          <p class="lead" style="margin-bottom:4px;"><b style="color:var(--maroon-alt);">{{ m.report_label }}:</b> {{ nar.summary_lead }}</p>
          <ul class="findings">{% for b in nar.summary_bullets %}<li>{{ b }}</li>{% endfor %}</ul>
        {% else %}
          <p class="lead muted" style="margin-bottom:6px;"><b>{{ m.report_label }}:</b> engine not yet enabled <span style="color:var(--azure);font-style:italic;">[to be done]</span>.</p>
        {% endif %}
      {% endfor %}
    </div>
    {% if profile_implications %}
    <div class="block">
      <p class="section-label">Implications</p>
      {% for para in profile_implications %}<p class="lead" style="margin-bottom:6px;">{{ para }}</p>{% endfor %}
    </div>
    {% endif %}
  </div>
  <footer class="page__footer"><span>{{ date }}</span><span>{{ copyright }}</span><span>{{ pn }}</span></footer>
</section>

{# ============================================================ OVERALL (per motive) #}
{% elif pg.type == 'overall' %}
{% set m = M[pg.motive] %}{% set r = profile.motives[pg.motive] %}{% set nar = N[pg.motive] %}
<section class="page">
  <header class="page__header"><span class="mark">AIMS Motivation Report</span><span class="who">{{ profile.name }}</span><span class="spacer"></span><span class="tag">{{ m.display_name }}</span></header>
  {% if is_sample %}<span class="sample-chip">SAMPLE</span>{% endif %}
  <div class="page__body">
    <h1 class="page-title">Detail: {{ m.display_name }} Motive <span class="sub">(Percentiles)</span></h1>
    <div class="split">
      <div class="col-wide">
        {{ pbar(m.display_name, r, True) }}
        <div class="block" style="margin-top:10px;">
          <p class="section-label">Key Findings</p>
          <p class="lead">{{ nar.overall_lead }}</p>
        </div>
        <div class="block">
          <p class="section-label">Implications</p>
          <div class="twocol">
            <div>
              <p class="subhead good">Positive</p>
              <ul class="findings">
                {% for p in nar.overall_positives %}<li>{{ p }}</li>{% endfor %}
                {% if not nar.overall_positives %}<li class="muted">Limited positive expression evidence in this protocol.</li>{% endif %}
              </ul>
            </div>
            <div>
              <p class="subhead warn">Challenges</p>
              <ul class="findings">
                {% for c in nar.overall_challenges %}<li>{{ c }}</li>{% endfor %}
                {% if not nar.overall_challenges %}<li class="muted">No notable obstacle or negative-affect themes.</li>{% endif %}
              </ul>
            </div>
          </div>
        </div>
      </div>
      <div class="col-narrow">
        <div class="summary-box">
          <div class="ttl">S U M M A R Y</div>
          <p style="margin:0 0 6px;">{{ m.display_name }} motive is <b>{{ m.one_liner }}</b>. {{ m.long_definition }}</p>
          <p style="margin:0;font-weight:600;color:var(--maroon-alt);font-size:10px;">People with this motive may:</p>
          <ul>{% for s in m.summary_bullets %}<li>{{ s }}</li>{% endfor %}</ul>
          <p style="margin:8px 0 2px;font-weight:600;color:var(--maroon-alt);font-size:10px;">Examples of appealing jobs:</p>
          <ul>{% for j in m.example_jobs %}<li>{{ j }}</li>{% endfor %}</ul>
        </div>
      </div>
    </div>
  </div>
  <footer class="page__footer"><span>{{ date }}</span><span>{{ copyright }}</span><span>{{ pn }}</span></footer>
</section>

{# ============================================================ EXPRESSIONS (per motive) #}
{% elif pg.type == 'expressions' %}
{% set m = M[pg.motive] %}{% set r = profile.motives[pg.motive] %}{% set nar = N[pg.motive] %}
<section class="page">
  <header class="page__header"><span class="mark">AIMS Motivation Report</span><span class="who">{{ profile.name }}</span><span class="spacer"></span><span class="tag">{{ m.display_name }}</span></header>
  {% if is_sample %}<span class="sample-chip">SAMPLE</span>{% endif %}
  <div class="page__body">
    <h1 class="page-title">Detail: {{ m.display_name }} Motive <span class="sub">(Expressions)</span></h1>
    <div class="block">
      <p class="section-label">Key Findings</p>
      <p class="lead">{{ nar.expressions_lead }}</p>
    </div>
    <div class="split">
      <div class="col-wide">
        <p class="section-label">Implications</p>
        <ul class="findings">
          {% for p in nar.expressions_points %}<li>{{ p }}</li>{% endfor %}
          {% if not nar.expressions_points %}<li class="muted">Minimal scoreable content for this motive.</li>{% endif %}
        </ul>
        {% if nar.similar_people %}
        <p class="subhead" style="margin-top:10px;">People with similar categories</p>
        <ul class="findings">{% for s in nar.similar_people %}<li>{{ s }}</li>{% endfor %}</ul>
        {% endif %}
      </div>
      <div class="col-narrow">
        <table class="expr-table">
          <thead><tr><th>Story element</th><th>Evidence</th></tr></thead>
          <tbody>
            {% for e in r.expressions %}
            <tr>
              <td class="el" title="{{ e.definition }}">{{ e.label }}</td>
              <td>{{ meter(e.evidence) }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        <p class="note">Evidence reflects how often each element appears across the {{ r.n_stories }} stories.</p>
      </div>
    </div>
  </div>
  <footer class="page__footer"><span>{{ date }}</span><span>{{ copyright }}</span><span>{{ pn }}</span></footer>
</section>

{# ============================================================ APPENDIX DIVIDER #}
{% elif pg.type == 'appendix_divider' %}
<section class="page appendix-divider">
  <div class="left">
    <h1>Appendix</h1>
    <ul>
      <li>Assessment Details &amp; Methodology</li>
      <li>Implicit Motivation Definitions</li>
      <li>Motive Story Elements</li>
      {% if internal %}<li>Per-Story Evidence (internal)</li>{% endif %}
    </ul>
  </div>
  <div class="rail">
    <div class="wm">AIMS</div>
    <div class="wm-words"><div>AI-Powered</div><div>Implicit</div><div>Motive</div><div>System</div></div>
  </div>
</section>

{# ============================================================ APPENDIX DEFINITIONS #}
{% elif pg.type == 'appendix_defs' %}
<section class="page">
  <header class="page__header"><span class="mark">AIMS Motivation Report</span><span class="who">{{ profile.name }}</span><span class="spacer"></span><span class="tag">Appendix</span></header>
  <div class="page__body">
    <h1 class="page-title">Definitions: Implicit Motivation</h1>
    <table class="def-table">
      <thead><tr><th>Dimension</th><th>Definition &amp; subtypes</th></tr></thead>
      <tbody>
        {% for m in motives %}
        <tr>
          <td class="dim">{{ m.display_name }} Motive</td>
          <td><b style="color:var(--ink-charcoal);">{{ m.long_definition }}</b>
            <div class="sub" style="margin-top:5px;">
              {% for name, desc in m.subtypes %}<div><b>{{ name }}:</b> {{ desc }}</div>{% endfor %}
            </div></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <div class="callout" style="margin-top:14px;">
      <b>Methodology.</b> Each subject writes short imaginative stories to ambiguous pictures
      (a Picture Story Exercise / TAT). An AI ensemble scores each story for McClelland's motive
      content categories; per-subject totals are length-corrected and converted to sample-relative
      percentiles. End users see percentiles, plain-language narrative, and role-relevant
      implications — never raw category scores.
    </div>
    <p class="note" style="margin-top:10px;">Reproducibility — engine <b>{{ meta.engine }}</b> ·
      provider <b>{{ meta.provider }}</b> · {{ meta.ensemble_n }} samples/story · temperature
      <b>{{ meta.temperature }}</b> · seed <b>{{ meta.seed }}</b> · length-correction
      <b>{{ meta.wc_correction }}</b> · reference cohort <b>{{ meta.cohort }}</b>. Percentiles are
      sample-relative and reproducible for a fixed cohort version; a change to this cohort id is the
      only thing that should move a percentile on identical input.</p>
  </div>
  <footer class="page__footer"><span>{{ date }}</span><span>{{ copyright }}</span><span>{{ pn }}</span></footer>
</section>

{# ============================================================ APPENDIX STORY ELEMENTS #}
{% elif pg.type == 'appendix_elements' %}
<section class="page">
  <header class="page__header"><span class="mark">AIMS Motivation Report</span><span class="who">{{ profile.name }}</span><span class="spacer"></span><span class="tag">Appendix</span></header>
  <div class="page__body">
    <h1 class="page-title">Motive Story Elements in Detail</h1>
    <p class="lead muted">The “story elements” describe in more detail in what ways a person's
    motivation is expressed — their needs, their actions and concerns around blocks, whether they
    anticipate positive or negative results, and their feelings around accomplishment.</p>
    {% for m in motives %}
      {% set r = profile.motives.get(m.key) %}
      {% if r and r.enabled %}
      <p class="section-label" style="margin-top:10px;">{{ m.display_name }} — elements</p>
      <table class="expr-table">
        <thead><tr><th>Element</th><th>Definition</th><th>Evidence</th></tr></thead>
        <tbody>
          {% for e in r.expressions %}
          <tr><td class="el">{{ e.label }}</td><td>{{ e.definition }}</td><td>{{ meter(e.evidence) }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}
    {% endfor %}
  </div>
  <footer class="page__footer"><span>{{ date }}</span><span>{{ copyright }}</span><span>{{ pn }}</span></footer>
</section>

{# ============================================================ APPENDIX EVIDENCE (internal) #}
{% elif pg.type == 'appendix_evidence' %}
<section class="page">
  <header class="page__header"><span class="mark">AIMS Motivation Report</span><span class="who">{{ profile.name }}</span><span class="spacer"></span><span class="tag">Internal</span></header>
  <div class="page__body">
    <h1 class="page-title">Per-Story Evidence <span class="sub">(internal / clinical view)</span></h1>
    <p class="note">Engine explanations behind the gate decision for each scored story. Not shown in the candidate-facing report.</p>
    {% for m in motives %}
      {% set r = profile.motives.get(m.key) %}
      {% if r and r.enabled and r.evidence_quotes %}
      <p class="section-label" style="margin-top:10px;">{{ m.display_name }}</p>
      <ul class="evidence-list">{% for q in r.evidence_quotes %}<li>{{ q }}</li>{% endfor %}</ul>
      {% endif %}
    {% endfor %}
  </div>
  <footer class="page__footer"><span>{{ date }}</span><span>{{ copyright }}</span><span>{{ pn }}</span></footer>
</section>
{% endif %}
{% endfor %}

</body>
</html>
